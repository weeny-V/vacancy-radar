{
  "name": "vacancy-radar",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @vacancy-radar/api\" \"npm run dev --workspace @vacancy-radar/web\" \"npm run dev --workspace @vacancy-radar/worker\"",
    "build": "npm run build --workspace @vacancy-radar/shared && npm run build --workspace @vacancy-radar/api && npm run build --workspace @vacancy-radar/worker && npm run build --workspace @vacancy-radar/web",
    "test": "vitest run",
    "lint": "npm run lint --workspaces --if-present",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:baseline": "prisma migrate resolve --applied 20260615090000_init",
    "prisma:seed": "tsx prisma/seed.ts",
    "docker:up": "docker compose up --build"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "concurrently": "^8.2.2",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@prisma/client": "^5.18.0"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
